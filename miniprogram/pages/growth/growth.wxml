<!--growth.wxml-->
<scroll-view class="scrollarea" scroll-y>
  <view class="page-container">

    <view class="notice-bar">
      <text class="notice-icon">!</text>
      <text class="notice-text">各项数值须在未出战、无套装状态下查看，计算结果略有误差仅供参考。成长率类别较准确，具体数值可能有波动，5级可携带计算偏差较大。</text>
    </view>

    <view class="section">
      <view class="section-title">输入信息</view>

      <view class="input-group">
        <view class="input-label">携带等级</view>
        <picker mode="selector" range="{{carryLevelOptions}}" range-key="label" value="{{0}}" bindchange="onCarryLevelChange">
          <view class="picker-field">
            <text>{{carryLevel}}级可携带</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="input-group">
        <view class="input-label">体力资质</view>
        <input class="input-field" type="digit" placeholder="请输入体力资质" value="{{vitAptitude}}" bindinput="onVitAptitudeInput" />
      </view>

      <view class="input-group">
        <view class="input-label">当前等级</view>
        <input class="input-field" type="digit" placeholder="请输入当前等级" value="{{currentLevel}}" bindinput="onCurrentLevelInput" />
      </view>

      <view class="input-group">
        <view class="input-label">当前血量</view>
        <input class="input-field" type="digit" placeholder="请输入当前血量" value="{{currentHp}}" bindinput="onCurrentHpInput" />
      </view>

      <view class="input-group">
        <view class="input-label">体力点数</view>
        <input class="input-field" type="digit" placeholder="请输入体力点数" value="{{vitPoints}}" bindinput="onVitPointsInput" />
      </view>
    </view>

    <view class="btn-group">
      <button class="btn btn-primary" bindtap="onCalculate">计算成长率</button>
      <button class="btn btn-secondary" bindtap="onReset">重置</button>
    </view>

    <view class="section result-section" wx:if="{{showResult && result}}">
      <view class="section-title">计算结果</view>
      <view class="result-card">
        <view class="result-row highlight">
          <text class="result-label">成长率</text>
          <text class="result-value primary">{{result.growthRateStr}}</text>
        </view>
        <view class="result-row">
          <text class="result-label">取整成长率</text>
          <text class="result-value">{{result.growthRateRounded}}</text>
        </view>
        <view class="result-divider"></view>
        <view class="result-row">
          <text class="result-label">成长类别</text>
          <text class="result-value type-badge {{result.growthTypeStr}}">{{result.growthTypeStr}}</text>
        </view>
        <view class="result-row">
          <text class="result-label">所属区间</text>
          <text class="result-value">{{result.rangeLabel}}</text>
        </view>
        <view class="result-divider"></view>
        <view class="progress-section">
          <view class="progress-header">
            <text class="result-label">区间进度</text>
            <text class="result-value">{{result.progressStr}}</text>
          </view>
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{result.progressPercent}}%;"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="section ref-table-section">
      <view class="section-title ref-table-header" bindtap="onToggleRefTable">
        <text>成长率参考表</text>
        <text class="toggle-icon">{{showRefTable ? '▼' : '▶'}}</text>
      </view>
      <view class="ref-table-content" wx:if="{{showRefTable}}">
        <scroll-view scroll-x class="ref-table-scroll">
          <view class="ref-table">
            <view class="ref-table-row ref-table-header-row">
              <text class="ref-cell ref-cell-level">携带等级</text>
              <text class="ref-cell">普通</text>
              <text class="ref-cell">优秀</text>
              <text class="ref-cell">杰出</text>
              <text class="ref-cell">卓越</text>
              <text class="ref-cell ref-cell-perfect">完美</text>
            </view>
            <view class="ref-table-row" wx:for="{{refTable}}" wx:key="carryLevel">
              <text class="ref-cell ref-cell-level">{{item.label}}</text>
              <text class="ref-cell">{{item.normal}}</text>
              <text class="ref-cell">{{item.excellent}}</text>
              <text class="ref-cell">{{item.outstanding}}</text>
              <text class="ref-cell">{{item.epic}}</text>
              <text class="ref-cell ref-cell-perfect">{{item.perfect}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <view class="bottom-spacer"></view>
  </view>
</scroll-view>
