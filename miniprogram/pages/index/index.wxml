<!--index.wxml-->
<image class="page-bg" src="/images/home-bg.png" mode="aspectFill"></image>

<view class="hero-inner">
  <view class="hero-greet">少侠</view>
  <view class="hero-name">{{nickname || '初来乍到'}}</view>
  <text class="hero-id" wx:if="{{userId}}">#{{userId}}</text>
</view>
<view class="hero-seal">墨狐</view>

<scroll-view class="scrollarea" scroll-y>
  <view class="container">
    <view class="tool-list">
      <view class="tool-card" bindtap="goToBeastCalc">
        <view class="tool-icon">🦁</view>
        <view class="tool-info">
          <text class="tool-name">资质计算器</text>
          <text class="tool-desc">根据悟性、灵性等级计算资质</text>
        </view>
        <text class="tool-arrow">›</text>
      </view>
      <view class="tool-card" bindtap="goToGrowthCalc">
        <view class="tool-icon">📈</view>
        <view class="tool-info">
          <text class="tool-name">成长率计算器</text>
          <text class="tool-desc">通过血量反推成长率与类别</text>
        </view>
        <text class="tool-arrow">›</text>
      </view>
      <view class="tool-card" bindtap="goToGameRecord">
        <view class="tool-icon">🏕️</view>
        <view class="tool-info">
          <text class="tool-name">回归与挂机设置</text>
          <text class="tool-desc">记录账号回归与野外挂机，掌握角色历练进度</text>
        </view>
        <text class="tool-arrow">›</text>
      </view>
    </view>
  </view>
</scroll-view>
