{
  "description": "计算器小工具",
  "miniprogramRoot": "miniprogram/",
  "cloudfunctionRoot": "cloudfunctions/",
  "compileType": "miniprogram",
  "appid": "wx51cbd40caf48c279",
  "libVersion": "2.25.4",
  "setting": {
    "useCompilerPlugins": ["typescript", "sass"],
    "es6": true,
    "es6ToEs5": true,
